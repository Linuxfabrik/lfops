# {{ ansible_managed }}
# 2026050801

[linuxfabrik-monitoring-plugins-release]
name=Linuxfabrik Monitoring Plugins (release)
{% if repo_monitoring_plugins__mirror_url is defined and repo_monitoring_plugins__mirror_url | length %}
baseurl={{ repo_monitoring_plugins__mirror_url }}/linuxfabrik/monitoring-plugins/sle/$releasever_major/release/
{% else %}
baseurl=https://repo.linuxfabrik.ch/monitoring-plugins/sle/$releasever_major/release/
{% endif %}
enabled={{ 0 if repo_monitoring_plugins__testing | bool else 1 }}
gpgcheck=1
gpgkey=https://repo.linuxfabrik.ch/linuxfabrik.key
{% if repo_monitoring_plugins__basic_auth_login is defined and repo_monitoring_plugins__basic_auth_login | length %}
username={{ repo_monitoring_plugins__basic_auth_login["username"] }}
password={{ repo_monitoring_plugins__basic_auth_login["password"] }}
{% endif %}

[linuxfabrik-monitoring-plugins-testing]
name=Linuxfabrik Monitoring Plugins (testing)
{% if repo_monitoring_plugins__mirror_url is defined and repo_monitoring_plugins__mirror_url | length %}
baseurl={{ repo_monitoring_plugins__mirror_url }}/linuxfabrik/monitoring-plugins/sle/$releasever_major/testing/
{% else %}
baseurl=https://repo.linuxfabrik.ch/monitoring-plugins/sle/$releasever_major/testing/
{% endif %}
enabled={{ 1 if repo_monitoring_plugins__testing | bool else 0 }}
gpgcheck=1
gpgkey=https://repo.linuxfabrik.ch/linuxfabrik.key
{% if repo_monitoring_plugins__basic_auth_login is defined and repo_monitoring_plugins__basic_auth_login | length %}
username={{ repo_monitoring_plugins__basic_auth_login["username"] }}
password={{ repo_monitoring_plugins__basic_auth_login["password"] }}
{% endif %}

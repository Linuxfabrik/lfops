[Unit]
Description=eXist-db Server
Documentation=https://exist-db.org/exist/apps/doc/
After=syslog.target

[Service]
Type=simple
User={{ existdb__user }}
Group={{ existdb__group }}
Environment="JAVA_HOME=/usr/lib/jvm/jre"
Environment="JAVA_OPTS={{ existdb__java_opts }}"
ExecStart={{ existdb__install_dir }}/bin/startup.sh

[Install]
WantedBy=multi-user.target

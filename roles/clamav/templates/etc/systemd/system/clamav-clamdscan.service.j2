# 2026060601

[Unit]
Description=ClamAV Full Scan via clamdscan

[Service]
ExecStart=/usr/bin/clamdscan --fdpass --multiscan --config-file={{ __clamav__clamd_config }} --log={{ __clamav__clamd_log }} --file-list={{ __clamav__filelist }}
Type=simple
User=root
# RETURN CODES (see `man clamdscan`)
# 0 : No virus found.
# 1 : Virus(es) found.
# 2 : An error occurred.
SuccessExitStatus=0 1

; {{ ansible_managed }}
; 2026032301

[grafana]
accessmode = "iframe"
datasource = "influxdb"
debug = "0"
defaultdashboard = "{{ icingaweb2_module_grafana__default_dashboard }}"
defaultdashboardpanelid = "1"
defaultdashboarduid = "default"
defaultorgid = "1"
host = "{{ (icingaweb2_module_grafana__url | split('://'))[1] }}"
protocol = "{{ (icingaweb2_module_grafana__url | split('://'))[0] }}"
shadows = "0"
theme = "{{ icingaweb2_module_grafana__theme }}"
timerange = "2d"
timerangeAll = "1w/w"
ssl_verifypeer = "0"
ssl_verifyhost = "0"
dashboardlink = "0"
{% if icingaweb2_module_grafana__auth_jwt %}
jwtEnable = "1"
jwtUser = "grafana-admin"
jwtIssuer = "https://{{ (icingaweb2_module_grafana__url | split('://'))[1] }}"
jwtExpires = "30"
{% endif %}

#!/usr/bin/env bash
# {{ ansible_managed }}
# 2026061201

output=$(/usr/bin/php /var/www/html/nextcloud/occ ldap:show-remnants)
if [ -z "$output" ]; then
    echo 'Got not output from ldap:show-remnants, maybe the user_ldap app is not enabled.'
    exit 0
fi

{% if nextcloud__mail_recipients | length > 0 %}
# only mail the output if recipients are configured
{
    echo "To: {{ nextcloud__mail_recipients | join(', ') }}"
    echo "Subject: $(hostname --short) - Users not available on LDAP anymore, but have remnants in Nextcloud"
    echo
    echo "$output"
} | /usr/sbin/sendmail -t -i
{% else %}
echo "$output"
{% endif %}
exit 0
